#:include 'gyre.inc'

module colloc_gl2_diff_m

   ! Uses

   use forum_m, only: RD

   use diff_m
   use eqns_m
   use ext_m
   use math_m
   use point_m
   use state_m

   use ISO_FORTRAN_ENV

   ! No implicit typing

   implicit none (type, external)

   ! Parameter definitions

   real(RD), parameter :: C_1 = 0.5_RD

   real(RD), parameter :: HALF_B_1 = 0.5_RD

   #:for S in DTYPE_SUFFIXES

      ! Derived-type definitions

      type, extends(diff_${S}$) :: colloc_gl2_diff_${S}$
         private
         class(eqns_${S}$), allocatable      :: eq(:)
         real(RD)                            :: dx
         procedure(eval_E_t_${S}$_), pointer :: eval_E_t_
      contains
         private
         procedure, public :: eval_E_t => eval_E_t_${S}$_
      end type colloc_gl2_diff_${S}$

      ! Interfaces

      interface colloc_gl2_diff_${S}$
         module procedure colloc_gl2_diff_${S}$_
      end interface colloc_gl2_diff_${S}$

      ! Access specifiers

      public :: colloc_gl2_diff_${S}$

   #:endfor

   ! Default access

   private

contains

   #:for T, S in zip(DTYPE_BASE_TYPES, DTYPE_SUFFIXES)

      function colloc_gl2_diff_${S}$_(eqns_factory, pt_a, pt_b) result(df)

         interface
            subroutine eqns_factory(pt, eq)
               use point_m
               use eqns_m
               implicit none (type, external)
               type(point_t), intent(in)                   :: pt(:)
               class(eqns_${S}$), allocatable, intent(out) :: eq(:)
            end subroutine eqns_factory
         end interface
         type(point_t), intent(in)   :: pt_a
         type(point_t), intent(in)   :: pt_b
         type(colloc_gl2_diff_${S}$) :: df

         type(point_t) :: pt(1)

         @:ASSERT_DEBUG(pt_a%s == pt_b%s, 'segment mismatch')

         ! Construct the colloc_gl2_diff type

         pt%s = pt_a%s

         df%dx = pt_b%x - pt_a%x
         pt%x = pt_a%x + [C_1]*df%dx

         call eqns_factory(pt, df%eq)

         df%n_e = df%eq(1)%n_e

         select case(df%n_e)
         case(2)
            df%eval_E_t_ => eval_E_t_2_${S}$_
         case(4)
            df%eval_E_t_ => eval_E_t_4_${S}$_
         case(6)
            df%eval_E_t_ => eval_E_t_6_${S}$_
         case default
            df%eval_E_t_ => eval_E_t_gen_${S}$_
         end select

         ! Finish

         return

      end function colloc_gl2_diff_${S}$_

      !****

      subroutine eval_E_t_${S}$_(this, st, E_t, scl, F)

         class(colloc_gl2_diff_${S}$), intent(in) :: this
         class(state_${S}$), intent(in)           :: st
         ${T}$, contiguous, intent(out)           :: E_t(:,:)
         type(ext_${S}$), intent(out)             :: scl
         ${T}$, contiguous, intent(out), optional :: F(:)

         ! Evaluate the transposed difference equations

         call this%eval_E_t_(st, E_t, scl, F)

         ! Finish

         return

      end subroutine eval_E_t_${S}$_

      !****

      #:for I, N_E in [ &
         ['2', 2], &
         ['4', 4], &
         ['6', 6], &
         ['gen', 'this%n_e']]

         subroutine eval_E_t_${I}$_${S}$_(this, st, E_t, scl, F)

            class(colloc_gl2_diff_${S}$), intent(in) :: this
            class(state_${S}$), intent(in)           :: st
            ${T}$, contiguous, intent(out)           :: E_t(:,:)
            type(ext_${S}$), intent(out)             :: scl
            ${T}$, contiguous, intent(out), optional :: F(:)

            integer :: j

            @:CHECK_BOUNDS(SIZE(E_t, 1), 2*this%n_e)
            @:CHECK_BOUNDS(SIZE(E_t, 2), this%n_e)

            if (PRESENT(F)) then
               @:CHECK_BOUNDS(SIZE(F), this%n_e)
            end if

            ! Evaluate the transposed difference equations

            ! Algorithm note: this is equivalent to the modified
            ! midpoint method

            associate (n_e => ${N_E}$)

               call this%eq(1)%eval_A_t(st, HALF_B_1*this%dx, E_t(:n_e,:), F)

               F = -2._RD*F

               do concurrent (j = 1:n_e)
                  E_t(n_e+1:,j) = E_t(:n_e,j)
                  E_t(j,j) = E_t(j,j) + 1._RD
                  E_t(j+n_e,j) = E_t(j+n_e,j) - 1._RD
               end do

            end associate

            scl = ONE_${S}$

            ! Finish

            return

         end subroutine eval_E_t_${I}$_${S}$_

      #:endfor

   #:endfor

end module colloc_gl2_diff_m
