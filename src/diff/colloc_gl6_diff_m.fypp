#:include 'gyre.inc'

module colloc_gl6_diff_m

   ! Uses

   use forum_m, only: RD

   use blas_lapack_m
   use diff_m
   use eqns_m
   use ext_m
   use linalg_m
   use math_m
   use point_m
   use state_m

   use ISO_FORTRAN_ENV

   ! No implicit typing

   implicit none (type, external)

   ! Parameter definitions

   real(RD), parameter :: C_1 = 0.5_RD-sqrt(15._RD)/10._RD
   real(RD), parameter :: C_2 = 0.5_RD
   real(RD), parameter :: C_3 = 0.5_RD+sqrt(15._RD)/10._RD

   real(RD), parameter :: D_12 = sqrt(15._RD)/15._RD
   real(RD), parameter :: D_13 = sqrt(15._RD)/30._RD
   real(RD), parameter :: D_21 = -sqrt(15._RD)/24._RD
   real(RD), parameter :: D_23 = sqrt(15._RD)/24._RD
   real(RD), parameter :: D_31 = -sqrt(15._RD)/30._RD
   real(RD), parameter :: D_32 = -sqrt(15._RD)/15._RD

   real(RD), parameter :: HALF_B_1 = 5._RD/36._RD
   real(RD), parameter :: HALF_B_2 = 4._RD/18._RD
   real(RD), parameter :: HALF_B_3 = 5._RD/36._RD

   #:for T, S in zip(DTYPE_BASE_TYPES, DTYPE_SUFFIXES)

      ! Derived-type definitions

      type, extends(diff_${S}$) :: colloc_gl6_diff_${S}$
         private
         class(eqns_${S}$), allocatable            :: eq(:)
         real(RD)                                  :: dx
         procedure(eval_E_t_hom_${S}$_), pointer   :: eval_E_t_hom_
         procedure(eval_E_t_inhom_${S}$_), pointer :: eval_E_t_inhom_
      contains
         private
         procedure, public :: eval_E_t => eval_E_t_${S}$_
      end type colloc_gl6_diff_${S}$

      ! Interfaces

      interface

         subroutine eval_E_t_hom_${S}$_(this, st, E_t, scl)
            use forum_m, only: RD
            use ext_m
            use state_m
            import colloc_gl6_diff_${S}$
            class(colloc_gl6_diff_${S}$), intent(in) :: this
            class(state_${S}$), intent(in)           :: st
            ${T}$, contiguous, intent(out)           :: E_t(:,:)
            type(ext_${S}$), intent(out)             :: scl
         end subroutine eval_E_t_hom_${S}$_

         subroutine eval_E_t_inhom_${S}$_(this, st, E_t, scl, F)
            use forum_m, only: RD
            use ext_m
            use state_m
            import colloc_gl6_diff_${S}$
            class(colloc_gl6_diff_${S}$), intent(in) :: this
            class(state_${S}$), intent(in)           :: st
            ${T}$, contiguous, intent(out)           :: E_t(:,:)
            type(ext_${S}$), intent(out)             :: scl
            ${T}$, contiguous, intent(out)           :: F(:)
         end subroutine eval_E_t_inhom_${S}$_

      end interface

      interface colloc_gl6_diff_${S}$
         module procedure colloc_gl6_diff_${S}$_
      end interface colloc_gl6_diff_${S}$

      ! Access specifiers

      public :: colloc_gl6_diff_${S}$

   #:endfor

   ! Default access

   private

contains

   #:for T, S in zip(DTYPE_BASE_TYPES, DTYPE_SUFFIXES)

      function colloc_gl6_diff_${S}$_(eqns_factory, pt_a, pt_b) result(df)

         interface
            subroutine eqns_factory(pt, eq)
               use point_m
               use eqns_m
               implicit none (type, external)
               type(point_t), intent(in)                   :: pt(:)
               class(eqns_${S}$), allocatable, intent(out) :: eq(:)
            end subroutine eqns_factory
         end interface
         type(point_t), intent(in)   :: pt_a
         type(point_t), intent(in)   :: pt_b
         type(colloc_gl6_diff_${S}$) :: df

         type(point_t) :: pt(3)

         @:ASSERT_DEBUG(pt_a%s == pt_b%s, 'segment mismatch')

         ! Construct the colloc_gl6_diff type

         pt%s = pt_a%s

         df%dx = pt_b%x - pt_a%x
         pt%x = pt_a%x + [C_1,C_2,C_3]*df%dx

         call eqns_factory(pt, df%eq)

         df%n_e = df%eq(1)%n_e

         select case(df%n_e)
         case(2)
            df%eval_E_t_hom_ => eval_E_t_hom_2_${S}$_
            df%eval_E_t_inhom_ => eval_E_t_inhom_2_${S}$_
         case(4)
            df%eval_E_t_hom_ => eval_E_t_hom_4_${S}$_
            df%eval_E_t_inhom_ => eval_E_t_inhom_4_${S}$_
         case(6)
            df%eval_E_t_hom_ => eval_E_t_hom_6_${S}$_
            df%eval_E_t_inhom_ => eval_E_t_inhom_6_${S}$_
         case default
            df%eval_E_t_hom_ => eval_E_t_hom_gen_${S}$_
            df%eval_E_t_inhom_ => eval_E_t_inhom_gen_${S}$_
         end select

         ! Finish

         return

      end function colloc_gl6_diff_${S}$_

      !****

      subroutine eval_E_t_${S}$_(this, st, E_t, scl, F)

         class(colloc_gl6_diff_${S}$), intent(in) :: this
         class(state_${S}$), intent(in)           :: st
         ${T}$, contiguous, intent(out)           :: E_t(:,:)
         type(ext_${S}$), intent(out)             :: scl
         ${T}$, contiguous, intent(out), optional :: F(:)

         ! Evaluate the transposed difference equations

         if (PRESENT(F)) then
            call this%eval_E_t_inhom_(st, E_t, scl, F)
         else
            call this%eval_E_t_hom_(st, E_t, scl)
         end if

         ! Finish

         return

      end subroutine eval_E_t_${S}$_

      !****

      #:for I, N_E in [ &
         ['2', 2], &
         ['4', 4], &
         ['6', 6], &
         ['gen', 'this%n_e']]

         subroutine eval_E_t_hom_${I}$_${S}$_(this, st, E_t, scl)

            class(colloc_gl6_diff_${S}$), intent(in) :: this
            class(state_${S}$), intent(in)           :: st
            ${T}$, contiguous, intent(out)           :: E_t(:,:)
            type(ext_${S}$), intent(out)             :: scl

            ${T}$   :: A_1(${N_E}$,${N_E}$)
            ${T}$   :: A_2(${N_E}$,${N_E}$)
            ${T}$   :: A_3(${N_E}$,${N_E}$)
            ${T}$   :: A_12(${N_E}$,${N_E}$)
            ${T}$   :: A_13(${N_E}$,${N_E}$)
            ${T}$   :: P_22(${N_E}$,${N_E}$)
            ${T}$   :: P_23(${N_E}$,${N_E}$)
            ${T}$   :: P_33(${N_E}$,${N_E}$)
            ${T}$   :: M(2*${N_E}$,${N_E}$)
            ${T}$   :: K_1(${N_E}$,${N_E}$)
            ${T}$   :: K_2(${N_E}$,${N_E}$)
            ${T}$   :: K_3(${N_E}$,${N_E}$)
            integer :: i

            @:CHECK_BOUNDS(SIZE(E_t, 1), 2*this%n_e)
            @:CHECK_BOUNDS(SIZE(E_t, 2), this%n_e)

            ! Evaluate the transposed difference equations

            ! Algorithm note: this is Gauss-Legendre collocation with
            ! 3 intermediate stages

            associate (n_e => ${N_E}$)

               call this%eq(1)%eval_A_t(st, this%dx, A_1)
               call this%eq(2)%eval_A_t(st, this%dx, A_2)
               call this%eq(3)%eval_A_t(st, this%dx, A_3)

               A_12 = MATMUL(A_1, A_2)
               A_13 = MATMUL(A_1, A_3)

               K_1 = A_1

               K_2 = A_2 - D_21*A_12

               P_22 = -D_21*D_12*A_12

               do concurrent(i = 1:n_e)
                  P_22(i,i) = P_22(i,i) + 1._RD
               end do

               P_23 = D_23*A_2 - D_21*D_13*A_12

               M(:n_e,:) = P_23
               M(n_e+1:,:) = K_2

               #:if I == 'gen'
                  call trans_solve(P_22, M)
               #:else
                  call trans_solve_${I}$(P_22, M)
               #:endif

               P_22 = D_32*A_3 - D_31*D_12*A_13

               K_3 = A_3 - D_31*A_13 - MATMUL(M(n_e+1:,:), P_22)

               P_33 = -D_31*D_13*A_13 - MATMUL(M(:n_e,:), P_22)

               do concurrent(i = 1:n_e)
                  P_33(i,i) = P_33(i,i) + 1._RD
               end do

               #:if I == 'gen'
                  call trans_solve(P_33, K_3)
               #:else
                  call trans_solve_${I}$(P_33, K_3)
               #:endif

               K_2 = M(n_e+1:,:) - MATMUL(K_3, M(:n_e,:))

               K_1 = K_1 - MATMUL(D_12*K_2 + D_13*K_3, A_1)

               ! Assemble the difference equations

               do concurrent(i = 1:n_e)
                  E_t(:n_e,i) = HALF_B_1*K_1(:,i) + HALF_B_2*K_2(:,i) + HALF_B_3*K_3(:,i)
                  E_t(n_e+1:,i) = E_t(:n_e,i)
                  E_t(i,i) = E_t(i,i) + 1._RD
                  E_t(n_e+i,i) = E_t(n_e+i,i) - 1._RD
               end do

            end associate

            scl = ONE_${S}$

            ! Finish

            return

         end subroutine eval_E_t_hom_${I}$_${S}$_

         !****

         subroutine eval_E_t_inhom_${I}$_${S}$_(this, st, E_t, scl, F)

            class(colloc_gl6_diff_${S}$), intent(in) :: this
            class(state_${S}$), intent(in)           :: st
            ${T}$, contiguous, intent(out)           :: E_t(:,:)
            type(ext_${S}$), intent(out)             :: scl
            ${T}$, contiguous, intent(out)           :: F(:)

            ${T}$   :: A_1(${N_E}$,${N_E}$)
            ${T}$   :: A_2(${N_E}$,${N_E}$)
            ${T}$   :: A_3(${N_E}$,${N_E}$)
            ${T}$   :: F_1(${N_E}$)
            ${T}$   :: F_2(${N_E}$)
            ${T}$   :: F_3(${N_E}$)
            ${T}$   :: A_12(${N_E}$,${N_E}$)
            ${T}$   :: A_13(${N_E}$,${N_E}$)
            ${T}$   :: P_22(${N_E}$,${N_E}$)
            ${T}$   :: P_23(${N_E}$,${N_E}$)
            ${T}$   :: P_33(${N_E}$,${N_E}$)
            ${T}$   :: M(2*${N_E}$+1,${N_E}$)
            ${T}$   :: KL_1(${N_E}$+1,${N_E}$)
            ${T}$   :: KL_2(${N_E}$+1,${N_E}$)
            ${T}$   :: KL_3(${N_E}$+1,${N_E}$)
            integer :: i

            @:CHECK_BOUNDS(SIZE(E_t, 1), 2*this%n_e)
            @:CHECK_BOUNDS(SIZE(E_t, 2), this%n_e)

            @:CHECK_BOUNDS(SIZE(F), this%n_e)

            ! Evaluate the transposed difference equations and
            ! inhomogeneous vector

            ! Algorithm note: this is Gauss-Legendre collocation with
            ! 3 intermediate stages and an inhomogeneous term

            associate (n_e => ${N_E}$)

               call this%eq(1)%eval_A_t(st, this%dx, A_1, F_1)
               call this%eq(2)%eval_A_t(st, this%dx, A_2, F_2)
               call this%eq(3)%eval_A_t(st, this%dx, A_3, F_3)

               A_12 = MATMUL(A_1, A_2)
               A_13 = MATMUL(A_1, A_3)

               KL_1(:n_e,:) = A_1
               KL_1(n_e+1,:) = F_1

               KL_2(:n_e,:) = A_2 - D_21*A_12
               KL_2(n_e+1,:) = F_2 - D_21*MATMUL(F_1, A_2)

               P_22 = -D_21*D_12*A_12

               do concurrent(i = 1:n_e)
                  P_22(i,i) = P_22(i,i) + 1._RD
               end do

               P_23 = D_23*A_2 - D_21*D_13*A_12

               M(:n_e,:) = P_23
               M(n_e+1:,:) = KL_2

               #:if I == 'gen'
                  call trans_solve(P_22, M)
               #:else
                  call trans_solve_${I}$(P_22, M)
               #:endif

               P_22 = D_32*A_3 - D_31*D_12*A_13

               KL_3(:n_e,:) = A_3 - D_31*A_13 - MATMUL(M(n_e+1:2*n_e,:), P_22)
               KL_3(n_e+1,:) = F_3 - D_31*MATMUL(F_1, A_3) - MATMUL(M(2*n_e+1,:), P_22)

               P_33 = -D_31*D_13*A_13 - MATMUL(M(:n_e,:), P_22)

               do concurrent(i = 1:n_e)
                  P_33(i,i) = P_33(i,i) + 1._RD
               end do

               #:if I == 'gen'
                  call trans_solve(P_33, KL_3)
               #:else
                  call trans_solve_${I}$(P_33, KL_3)
               #:endif

               KL_2 = M(n_e+1:,:) - MATMUL(KL_3, M(:n_e,:))

               KL_1 = KL_1 - MATMUL(D_12*KL_2 + D_13*KL_3, A_1)

               ! Assemble the difference equations

               do concurrent(i = 1:n_e)
                  E_t(:n_e,i) = HALF_B_1*KL_1(:n_e,i) + HALF_B_2*KL_2(:n_e,i) + HALF_B_3*KL_3(:n_e,i)
                  E_t(n_e+1:,i) = E_t(:n_e,i)
                  E_t(i,i) = E_t(i,i) + 1._RD
                  E_t(n_e+i,i) = E_t(n_e+i,i) - 1._RD
               end do

               F = -2._RD*(HALF_B_1*KL_1(n_e+1,:) + HALF_B_2*KL_2(n_e+1,:) + HALF_B_3*KL_3(n_e+1,:))

            end associate

            scl = ONE_${S}$

            ! Finish

            return

         end subroutine eval_E_t_inhom_${I}$_${S}$_

      #:endfor

   #:endfor

end module colloc_gl6_diff_m
