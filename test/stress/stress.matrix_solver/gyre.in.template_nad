&constants
/

&model
  model_type = 'EVOL'
  file = 'spb.mesa'
  file_format = 'MESA'
/

&mode
  l = 2
/

&osc
  adiabatic = .FALSE.
  nonadiabatic = .TRUE.
/

&num
  diff_scheme = 'COLLOC_GL2'
  nad_matrix_solver = '{matrix_solver}'
  nad_search = 'FILE'
  file = 'summary.h5'
  file_format = 'SUMMARY'
  restrict_roots = .FALSE.
/

&scan
/

&rot
/

&grid
  w_osc = 50
  w_exp = 10
  w_ctr = 50
/

&ad_output
/

&nad_output
/
